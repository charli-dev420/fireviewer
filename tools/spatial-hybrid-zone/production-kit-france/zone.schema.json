{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewarning.fr/schemas/france-map-production.v1.json",
  "title": "Production d'une carte FireViewer en France metropolitaine",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "quality_profile", "zone", "inputs", "attention_zones", "execution"],
  "properties": {
    "schema": {"const": "fireviewer.france-map-production.v1"},
    "quality_profile": {"type": "string", "minLength": 1},
    "zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zone_id", "revision", "package_id", "artifact_slug", "label", "origin_l93_m"],
      "properties": {
        "zone_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,63}$"},
        "revision": {"type": "integer", "minimum": 1},
        "package_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,95}$"},
        "artifact_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
        "label": {"type": "string", "minLength": 3},
        "origin_l93_m": {
          "type": "array",
          "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}],
          "items": false
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aoi_l93", "production_envelope_l93", "buildings_l93", "vegetation_l93", "roads_l93", "water_courses_l93", "water_segments_l93", "water_surfaces_l93"],
      "properties": {
        "aoi_l93": {"type": "string", "minLength": 1},
        "production_envelope_l93": {"type": "string", "minLength": 1},
        "buildings_l93": {"type": "string", "minLength": 1},
        "vegetation_l93": {"type": "string", "minLength": 1},
        "roads_l93": {"$ref": "#/$defs/nonEmptyPathArray"},
        "water_courses_l93": {"$ref": "#/$defs/pathArray"},
        "water_segments_l93": {"$ref": "#/$defs/pathArray"},
        "water_surfaces_l93": {"$ref": "#/$defs/pathArray"}
      }
    },
    "attention_zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "bounds_l93_m"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"},
          "label": {"type": "string", "minLength": 2},
          "bounds_l93_m": {
            "type": "array",
            "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}, {"type": "number"}],
            "items": false
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_root"],
      "properties": {
        "artifact_root": {"type": "string", "minLength": 1},
        "python_executable": {"type": "string", "default": "python"},
        "blender_executable": {"type": ["string", "null"]},
        "build_blender_scene": {"type": "boolean", "default": true},
        "expected_source_tile_count": {"type": ["integer", "null"], "minimum": 1}
      }
    }
  },
  "$defs": {
    "pathArray": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "nonEmptyPathArray": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
