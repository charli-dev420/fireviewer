{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewarning.fr/schemas/unity-manual-validation.v1.json",
  "title": "Validation manuelle Unity avant publication FireViewer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "decision",
    "approval_statement",
    "package_id",
    "zone_id",
    "revision",
    "reviewer",
    "reviewed_at_utc",
    "unity_version",
    "catalog_sha256",
    "preview_sha256",
    "checklist"
  ],
  "properties": {
    "schema": {"const": "fireviewer.unity-manual-validation.v1"},
    "decision": {"enum": ["accepted", "rejected"]},
    "approval_statement": {
      "enum": ["ACCEPTÉ POUR PUBLICATION", "REFUSÉ POUR PUBLICATION"]
    },
    "package_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,95}$"},
    "zone_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,63}$"},
    "revision": {"type": "integer", "minimum": 1},
    "reviewer": {"type": "string", "minLength": 2},
    "reviewed_at_utc": {"type": "string", "format": "date-time"},
    "unity_version": {"const": "6000.3.18f1"},
    "catalog_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "preview_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_loaded",
        "terrain_grounding",
        "vegetation_exclusions",
        "lod_streaming",
        "near_buildings",
        "no_blocking_visual_artifacts"
      ],
      "properties": {
        "catalog_loaded": {"type": "boolean"},
        "terrain_grounding": {"type": "boolean"},
        "vegetation_exclusions": {"type": "boolean"},
        "lod_streaming": {"type": "boolean"},
        "near_buildings": {"type": "boolean"},
        "no_blocking_visual_artifacts": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"const": "accepted"}}},
      "then": {
        "properties": {
          "approval_statement": {"const": "ACCEPTÉ POUR PUBLICATION"}
        }
      },
      "else": {
        "properties": {
          "approval_statement": {"const": "REFUSÉ POUR PUBLICATION"}
        }
      }
    }
  ]
}
