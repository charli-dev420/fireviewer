{
  "openapi": "3.1.0",
  "info": {
    "title": "Fire-Viewer API",
    "description": "Transactional incident registry with idempotent ingestion, conservative spatial matching, immutable audit events and viewer manifests.",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/incident/detect": {
      "post": {
        "tags": [
          "incidents"
        ],
        "summary": "Detect Incident",
        "operationId": "detect_incident_api_v1_incident_detect_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Idempotency-Key"
            }
          },
          {
            "name": "X-Source-Token",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 32,
                  "maxLength": 256
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Source-Token"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DetectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "201": {
            "description": "A new incident series was created."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/incident/{fire_id}": {
      "get": {
        "tags": [
          "incidents"
        ],
        "summary": "Get Incident",
        "operationId": "get_incident_api_v1_incident__fire_id__get",
        "parameters": [
          {
            "name": "fire_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Fire Id"
            }
