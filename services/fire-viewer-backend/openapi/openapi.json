  },
  "components": {
    "schemas": {
      "AssetLod": {
        "type": "string",
        "enum": [
          "mobile",
          "desktop"
        ],
        "title": "AssetLod"
      },
      "DetectionContext": {
        "properties": {
          "territory_code": {
            "type": "string",
            "maxLength": 3,
            "minLength": 2,
            "title": "Territory Code"
          },
          "toponyms": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 10,
            "title": "Toponyms"
          },
          "canonical_name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255,
                "minLength": 2
              },
              {
                "type": "null"
              }
            ],
            "title": "Canonical Name"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "territory_code"
        ],
        "title": "DetectionContext"
      },
      "DetectionRequest": {
        "properties": {
          "source": {
            "$ref": "#/components/schemas/SourceInput"
          },
          "observed_at": {
            "type": "string",
            "format": "date-time",
            "title": "Observed At"
          },
          "received_at": {
            "type": "string",
            "format": "date-time",
            "title": "Received At"
          },
          "geometry": {
            "$ref": "#/components/schemas/PointGeometryInput"
          },
          "evidence": {
            "$ref": "#/components/schemas/EvidenceInput"
          },
          "context": {
            "$ref": "#/components/schemas/DetectionContext"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "source",
          "observed_at",
          "received_at",
          "geometry",
          "evidence",
          "context"
        ],
        "title": "DetectionRequest"
      },
      "DetectionResponse": {
        "properties": {
          "observation_id": {
            "type": "string",
            "title": "Observation Id"
          },
          "decision": {
            "$ref": "#/components/schemas/MatchDecision"
          },
          "fire_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fire Id"
          },
          "episode_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Episode Id"
          },
          "proposed_fire_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Proposed Fire Id"
          },
          "proposed_episode_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Proposed Episode Id"
          },
          "score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "margin_to_second_candidate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Margin To Second Candidate"
          },
          "factors": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Factors"
          },
          "distance_m": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Distance M"
          },
          "review_reasons": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Review Reasons"
          },
          "public_confirmation": {
            "type": "string",
            "enum": [
              "pending",
              "not_applicable"
            ],
            "title": "Public Confirmation"
          },
          "policy_id": {
            "type": "string",
            "title": "Policy Id"
          },
          "trace_id": {
            "type": "string",
            "title": "Trace Id"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "observation_id",
          "decision",
          "public_confirmation",
          "policy_id",
          "trace_id"
        ],
        "title": "DetectionResponse"
      },
      "EpisodeSummary": {
        "properties": {
          "episode_id": {
            "type": "string",
            "title": "Episode Id"
          },
          "ordinal": {
            "type": "integer",
            "title": "Ordinal"
          },
          "status": {
            "$ref": "#/components/schemas/IncidentStatus"
          },
          "review_required": {
            "type": "boolean",
            "title": "Review Required"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "title": "Started At"
          },
          "last_observed_at": {
            "type": "string",
            "format": "date-time",
            "title": "Last Observed At"
          },
          "validated_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Validated At"
          },
          "ended_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ended At"
          },
          "is_current": {
            "type": "boolean",
            "title": "Is Current"
          },
          "version": {
            "type": "integer",
            "title": "Version"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "episode_id",
          "ordinal",
          "status",
          "review_required",
          "started_at",
          "last_observed_at",
          "is_current",
          "version"
        ],
        "title": "EpisodeSummary"
      },
      "EvidenceInput": {
        "properties": {
          "content_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$",
            "title": "Content Hash"
          },
          "license": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "License"
          },
          "external_reference": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "title": "External Reference"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "content_hash",
          "license"
        ],
        "title": "EvidenceInput"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IncidentPublicResponse": {
        "properties": {
          "fire_id": {
            "type": "string",
            "title": "Fire Id"
          },
          "canonical_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Canonical Name"
          },
          "visibility": {
            "$ref": "#/components/schemas/PublicVisibility"
          },
          "status": {
            "$ref": "#/components/schemas/IncidentStatus"
          },
          "current_episode_id": {
            "type": "string",
            "title": "Current Episode Id"
          },
          "location": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PointGeometryInput"
              },
              {
                "type": "null"
              }
            ]
          },
          "public_note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Public Note"
          },
          "last_observed_at": {
            "type": "string",
            "format": "date-time",
            "title": "Last Observed At"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "episodes": {
            "items": {
              "$ref": "#/components/schemas/EpisodeSummary"
            },
            "type": "array",
            "title": "Episodes"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "fire_id",
          "visibility",
          "status",
          "current_episode_id",
          "location",
          "last_observed_at",
          "created_at",
          "episodes"
        ],
        "title": "IncidentPublicResponse"
      },
      "IncidentStatus": {
        "type": "string",
        "enum": [
          "CANDIDATE",
          "UNDER_REVIEW",
          "ACTIVE_CONFIRMED",
          "MONITORING",
          "EXTINGUISHED",
          "CLOSED",
          "SUSPENDED",
          "REJECTED"
        ],
        "title": "IncidentStatus"
      },
      "ManifestAsset": {
        "properties": {
          "asset_id": {
            "type": "string",
            "title": "Asset Id"
          },
          "version": {
            "type": "integer",
            "title": "Version"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "sha256": {
            "type": "string",
            "title": "Sha256"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes"
          },
          "lod": {
            "$ref": "#/components/schemas/AssetLod"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "asset_id",
          "version",
          "url",
          "sha256",
          "size_bytes",
          "lod"
        ],
        "title": "ManifestAsset"
      },
      "ManifestFrame": {
        "properties": {
          "origin_wgs84": {
            "prefixItems": [
              {
                "type": "number",
                "maximum": 180.0,
                "minimum": -180.0
              },
              {
                "type": "number",
                "maximum": 90.0,
                "minimum": -90.0
              },
              {
                "type": "number"
              }
            ],
            "type": "array",
            "maxItems": 3,
            "minItems": 3,
