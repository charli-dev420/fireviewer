FV_ENVIRONMENT=development
FV_DATABASE_URL=sqlite:///./data/fire_viewer.db
# Neon/Vercel example:
# FV_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DATABASE?sslmode=require
FV_DATABASE_POOL_SIZE=2
FV_DATABASE_MAX_OVERFLOW=3
FV_DATABASE_POOL_RECYCLE_SECONDS=300
FV_DATABASE_STATEMENT_TIMEOUT_MS=15000
FV_DATABASE_SCHEMA_REVISION=f9c8b7a6d510

# Dispatcher agentique séparé de l'API et de la table job existante.
FV_AGENT_DISPATCH_ENABLED=false
FV_AGENT_MEDIA_ALLOWED_HOSTS=["private-media.example"]
# Objet JSON role -> révision immuable attendue, incluant le SHA-256 RT-DETR privé.
FV_AGENT_EXPECTED_MODEL_REVISIONS={}
FV_AGENT_RUNPOD_TRANSPORT=pod
# URL HTTPS du proxy RunPod du pod de recette, par exemple https://<pod>-8000.proxy.runpod.net
FV_AGENT_RUNPOD_POD_BASE_URL=
FV_AGENT_RUNPOD_POD_AUTH_TOKEN=
# Utilisés seulement après bascule explicite vers FV_AGENT_RUNPOD_TRANSPORT=serverless.
FV_AGENT_RUNPOD_ENDPOINT_ID=
FV_AGENT_RUNPOD_API_KEY=
FV_AGENT_EXECUTION_TIMEOUT_MS=900000
FV_AGENT_JOB_TTL_MS=3600000
FV_AGENT_POLL_INTERVAL_SECONDS=5
FV_AGENT_DISPATCH_LEASE_SECONDS=90
FV_AGENT_DISPATCH_MAX_ATTEMPTS=3
# Packages utilisateur privés : mêmes endpoints, tables et dispatcher en test et en production.
FV_AGENT_SOURCE_PACKAGE_MAX_FILES=500
FV_AGENT_SOURCE_PACKAGE_MAX_FILE_BYTES=536870912
FV_AGENT_SOURCE_PACKAGE_MAX_TOTAL_BYTES=2147483648
FV_AGENT_SOURCE_PACKAGE_RETENTION_DAYS=30
FV_AGENT_MEDIA_PROXY_BASE_URL=https://private-media.example
# Secret serveur aléatoire d'au moins 32 caractères ; ne jamais le versionner en production.
FV_AGENT_MEDIA_SIGNING_SECRET=development-only-agent-media-signing-secret-change-me
# Recherche Qwen réelle. Le registre et sa version sont verrouillés par le code.
FV_AGENT_RESEARCH_ENABLED=false
FV_AGENT_RESEARCH_SOURCE_REGISTRY_VERSION=firewarning-fr-sources-2026-07-19-v1
FV_AGENT_RESEARCH_MAX_FETCH_BYTES=26214400
FV_AGENT_RESEARCH_REQUEST_TIMEOUT_SECONDS=20
FV_OBJECT_STORAGE_BACKEND=local
FV_OBJECT_STORAGE_PREFIX=firewarning
# Connected automatically by a private Vercel Blob store. Keep it server-side only.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
FV_LOG_LEVEL=INFO
FV_AUTH_MODE=disabled
# Compte administrateur unique (développement et production initiale) :
# FV_AUTH_MODE=local_admin
# FV_LOCAL_ADMIN_USERNAME=admin
# FV_LOCAL_ADMIN_PASSWORD_HASH=scrypt$...
# FV_PUBLIC_REPORT_HASH_SECRET=au-moins-32-caracteres-aleatoires # gitleaks:allow
FV_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FV_TRUSTED_HOSTS=["localhost","127.0.0.1"]
FV_MAX_BODY_BYTES=1048576

# Required when FV_AUTH_MODE=jwt
# FV_OIDC_JWKS_URL=https://identity.example/.well-known/jwks.json
# FV_OIDC_ISSUER=https://identity.example/
# FV_OIDC_AUDIENCE=fire-viewer-api
# FV_OIDC_ROLES_CLAIM=roles
