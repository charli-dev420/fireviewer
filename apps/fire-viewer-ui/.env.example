# Choisir explicitement un seul mode. Seules les chaînes exactes true et false sont admises.
# Toute valeur absente ou invalide affiche « N/A — mode de données non configuré »
# sans requête réseau ni chargement de fixture.

# Dashboard fictif riche, local uniquement.
VITE_USE_MOCKS=true

# Pour consulter exclusivement le manifeste public réel, remplacer la ligne ci-dessus par :
# VITE_USE_MOCKS=false
# L'URL est une origine HTTP(S) pure, sans /api, /api/v1, query, fragment ni identifiants.
# VITE_API_BASE_URL=http://localhost:8000
# VITE_API_BASE_URL=https://api.example.org
# Le client utilise alors GET {origin}/api/v1/incident/{fire_id}/manifest.
