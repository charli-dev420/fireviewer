{
  "name": "fire-viewer-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "build:spatial": "npm run verify:spatial && npm run build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:spatial": "node --test tools/spatial-package-verifier.test.mjs tools/spatial-release.test.mjs",
    "verify:spatial": "node tools/verify-spatial-package.mjs",
    "pack:spatial": "node tools/pack-spatial-release.mjs",
    "fetch:spatial": "node tools/fetch-spatial-release.mjs",
    "test:e2e": "npm run verify:spatial && playwright test",
    "test:e2e:install": "playwright install chromium",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@vercel/blob": "^2.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.180.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.180.0",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
